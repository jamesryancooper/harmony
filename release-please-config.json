{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "9ecda34181acbec66e9484a229e08b6e73f92988",
  "release-type": "simple",
  "bump-minor-pre-major": false,
  "bump-patch-for-minor-pre-major": true,
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "package-name": "octon",
      "changelog-path": "CHANGELOG.md",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "refactor",
          "section": "Refactors"
        }
      ],
      "extra-files": [
        {
          "type": "yaml",
          "path": ".octon/octon.yml",
          "jsonpath": "$.versioning.harness.release_version"
        },
        {
          "type": "yaml",
          "path": ".octon/framework/manifest.yml",
          "jsonpath": "$.release_version"
        }
      ]
    }
  }
}
