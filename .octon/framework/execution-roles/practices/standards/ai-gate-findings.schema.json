{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/ai-gate-findings.schema.json",
  "title": "AI Gate Findings",
  "type": "object",
  "required": [
    "provider",
    "status",
    "generated_at",
    "summary",
    "findings"
  ],
  "properties": {
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "selected_route"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_route": {
          "type": "string",
          "enum": [
            "direct-main",
            "branch-no-pr",
            "branch-pr",
            "stage-only-escalate"
          ]
        },
        "change_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "pr_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "unavailable",
        "error"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "decision",
          "title",
          "body",
          "file"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "decision": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "block"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "class": {
            "type": "string",
            "enum": [
              "unnecessary-authority-surface",
              "proposal-authority-leak",
              "generated-authority-leak",
              "raw-input-runtime-dependency",
              "speculative-abstraction",
              "duplicate-logic",
              "dependency-without-receipt",
              "shallow-validation-evidence",
              "cleanup-pass-missing",
              "behavior-preservation-unproven",
              "unsupported-support-claim",
              "unregistered-retirement-residue"
            ]
          },
          "rule": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
