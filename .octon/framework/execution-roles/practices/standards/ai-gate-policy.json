{
  "version": "2026-03-03",
  "default_work_unit_policy_ref": ".octon/framework/product/contracts/default-work-unit.yml",
  "change_receipt_schema_ref": ".octon/framework/product/contracts/change-receipt-v1.schema.json",
  "route_scope": {
    "hosted_gate_route": "branch-pr",
    "no_pr_change_gate_required": false,
    "no_pr_evidence_modes": [
      "local_validation",
      "local_review_or_waiver",
      "change_receipt"
    ]
  },
  "enforcement": {
    "variable": "AI_GATE_ENFORCE",
    "default": false,
    "require_all_providers_available_when_enforced": true
  },
  "waiver": {
    "mode": "disabled"
  },
  "finding_classes": [
    {
      "id": "unnecessary-authority-surface",
      "default_decision": "block",
      "description": "New authored authority surface exists without clear durable ownership and enforcement need."
    },
    {
      "id": "proposal-authority-leak",
      "default_decision": "block",
      "description": "Active proposal content is treated as runtime, policy, support, or closure authority."
    },
    {
      "id": "generated-authority-leak",
      "default_decision": "block",
      "description": "Generated output is treated as source of truth or a second control plane."
    },
    {
      "id": "raw-input-runtime-dependency",
      "default_decision": "block",
      "description": "Raw input path is consumed as runtime or policy dependency."
    },
    {
      "id": "speculative-abstraction",
      "default_decision": "warn",
      "description": "New abstraction exists without current complexity, duplication, or local-pattern need."
    },
    {
      "id": "duplicate-logic",
      "default_decision": "warn",
      "description": "New helper, type, validator, policy, or workflow duplicates an existing surface."
    },
    {
      "id": "dependency-without-receipt",
      "default_decision": "block",
      "description": "Dependency change lacks the required decision receipt."
    },
    {
      "id": "shallow-validation-evidence",
      "default_decision": "warn",
      "description": "Tests or checks mirror implementation details without proving behavior or boundaries."
    },
    {
      "id": "cleanup-pass-missing",
      "default_decision": "warn",
      "description": "Non-trivial AI-assisted change lacks a cleanup pass result."
    },
    {
      "id": "behavior-preservation-unproven",
      "default_decision": "block",
      "description": "Behavior or boundary preservation claims lack supporting validation evidence."
    },
    {
      "id": "unsupported-support-claim",
      "default_decision": "block",
      "description": "Support claim exceeds admitted support targets or retained evidence."
    },
    {
      "id": "unregistered-retirement-residue",
      "default_decision": "warn",
      "description": "Transitional or historical residue lacks required retirement-register coverage."
    }
  ],
  "providers": [
    {
      "id": "openai",
      "required_secret": "OPENAI_API_KEY"
    },
    {
      "id": "anthropic",
      "required_secret": "ANTHROPIC_API_KEY"
    }
  ],
  "blocking": {
    "decisions": [
      "block"
    ],
    "severities": [
      "high",
      "critical"
    ]
  }
}
