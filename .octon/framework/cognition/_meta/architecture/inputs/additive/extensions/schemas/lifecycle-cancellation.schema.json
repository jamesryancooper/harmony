{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/schemas/lifecycle-cancellation.schema.json",
  "title": "Octon Lifecycle Cancellation Evidence",
  "description": "Durable cancellation marker or evidence for packet and program lifecycle runs.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "reason"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "octon-lifecycle-cancellation-v1",
        "octon-program-lifecycle-cancelled-v1"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "lifecycle_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "route-progression",
        "orchestrated-replan-loop"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "cancelled_at": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "cancellation_token": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_path": {
      "type": "string",
      "minLength": 1
    },
    "evidence_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
