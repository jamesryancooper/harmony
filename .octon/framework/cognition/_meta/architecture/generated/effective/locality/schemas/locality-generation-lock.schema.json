{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Locality Generation Lock",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "locality_manifest_sha256",
    "locality_registry_sha256",
    "quarantine_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-locality-generation-lock-v1"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
