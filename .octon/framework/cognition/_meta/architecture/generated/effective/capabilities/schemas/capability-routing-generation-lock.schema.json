{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Capability Routing Generation Lock",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "root_manifest_sha256",
    "extensions_catalog_sha256",
    "published_files"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-capability-routing-generation-lock-v1"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "published_files": {
      "type": "array"
    }
  }
}
