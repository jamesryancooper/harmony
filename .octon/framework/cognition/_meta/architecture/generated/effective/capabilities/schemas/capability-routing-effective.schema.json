{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effective Capability Routing",
  "type": "object",
  "required": [
    "schema_version",
    "generator_version",
    "generation_id",
    "published_at",
    "publication_status",
    "source",
    "routing_context",
    "routing_candidates",
    "resolution_order"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-capability-routing-effective-v2"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "publication_status": {
      "const": "published"
    },
    "routing_context": {
      "type": "object",
      "required": [
        "selector_schema_version",
        "locality_generation_id",
        "extension_generation_id",
        "host_projection_mode"
      ]
    },
    "routing_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "effective_id",
          "artifact_map_id",
          "origin_class",
          "capability_kind",
          "capability_id",
          "status",
          "host_adapters",
          "selectors",
          "fingerprints",
          "scope_relevance",
          "precedence_tier",
          "stable_sort_key"
        ]
      }
    },
    "resolution_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
