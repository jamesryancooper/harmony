{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/product/contracts/product-roadmap-v1.schema.json",
  "title": "Octon Product Roadmap v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "roadmap_role",
    "authority_note",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "octon-product-roadmap-v1"
    },
    "roadmap_role": {
      "const": "planning-only"
    },
    "authority_note": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "roadmap_item_id",
          "title",
          "status",
          "feature_id",
          "summary",
          "why_deferred",
          "owner_subsystems",
          "source_refs",
          "acceptance_criteria",
          "validation_refs",
          "completion_refs",
          "authority_notes"
        ],
        "properties": {
          "roadmap_item_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "suggested",
              "accepted",
              "planned",
              "in-progress",
              "completed",
              "rejected",
              "superseded"
            ]
          },
          "feature_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "why_deferred": {
            "type": "string",
            "minLength": 1
          },
          "owner_subsystems": {
            "$ref": "#/$defs/non_empty_string_array"
          },
          "source_refs": {
            "$ref": "#/$defs/reference_array"
          },
          "acceptance_criteria": {
            "$ref": "#/$defs/non_empty_string_array"
          },
          "validation_refs": {
            "$ref": "#/$defs/reference_array"
          },
          "completion_refs": {
            "$ref": "#/$defs/reference_array_or_empty"
          },
          "authority_notes": {
            "$ref": "#/$defs/non_empty_string_array"
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reference_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "reference_array_or_empty": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "authority_class"
      ],
      "oneOf": [
        {
          "required": [
            "path"
          ]
        },
        {
          "required": [
            "path_pattern"
          ]
        }
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "path_pattern": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "authority_class": {
          "type": "string",
          "enum": [
            "authored-authority",
            "product-contract",
            "runtime-spec",
            "runtime-implementation",
            "runtime-command",
            "publication-input-only",
            "generated-effective-non-authority",
            "retained-evidence",
            "retained-evidence-pattern",
            "validation",
            "navigation-only",
            "planning-only"
          ]
        }
      }
    }
  }
}
