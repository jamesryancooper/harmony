{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/intervention-log-v1.schema.json",
  "title": "Octon Intervention Log v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_kind",
    "subject_ref",
    "interventions",
    "summary",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "intervention-log-v1"
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "run",
        "harness"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "interventions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "kind",
          "disclosed"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "disclosed": {
            "type": "boolean"
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
