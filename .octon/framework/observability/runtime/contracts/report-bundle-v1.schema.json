{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/report-bundle-v1.schema.json",
  "title": "Octon Observability Report Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "subject_ref", "recorded_at"],
  "properties": {
    "schema_version": { "const": "observability-report-bundle-v1" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "minLength": 1 }
  }
}
