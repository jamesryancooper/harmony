{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/failure-taxonomy-v1.schema.json",
  "title": "Octon Failure Taxonomy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "taxonomy_id", "classes"],
  "properties": {
    "schema_version": { "const": "failure-taxonomy-v1" },
    "taxonomy_id": { "type": "string", "minLength": 1 },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["class_id", "description"],
        "properties": {
          "class_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
