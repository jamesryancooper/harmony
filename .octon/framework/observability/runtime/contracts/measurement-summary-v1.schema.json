{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/observability/runtime/contracts/measurement-summary-v1.schema.json",
  "title": "Octon Measurement Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_kind",
    "subject_ref",
    "metrics",
    "summary",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "measurement-summary-v1"
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "run",
        "harness"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric_id",
          "label",
          "value",
          "unit"
        ],
        "properties": {
          "metric_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
