{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/retention/run-evidence-classification-v2.schema.json",
  "title": "Octon Run Evidence Classification v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "artifacts",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "run-evidence-classification-v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "path_or_pointer",
          "evidence_class",
          "required_for_claim",
          "proof_planes",
          "retention_policy",
          "digest_or_locator"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "path_or_pointer": {
            "type": "string",
            "minLength": 1
          },
          "evidence_class": {
            "type": "string",
            "enum": [
              "git-inline",
              "git-pointer",
              "external-immutable",
              "generated-derived",
              "disclosure-derived"
            ]
          },
          "required_for_claim": {
            "type": "boolean"
          },
          "proof_planes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "structural",
                "functional",
                "behavioral",
                "maintainability",
                "governance",
                "recovery"
              ]
            }
          },
          "retention_policy": {
            "type": "string",
            "minLength": 1
          },
          "digest_or_locator": {
            "type": "string",
            "minLength": 1
          },
          "provenance_source": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
