{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/benchmark-suite-v1.schema.json",
  "title": "Octon Benchmark Suite v1",
  "description": "Comparative benchmark suite contract for raw, thin-wrapper, and Octon-governed execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_id",
    "baselines",
    "metrics",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "benchmark-suite-v1"
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
