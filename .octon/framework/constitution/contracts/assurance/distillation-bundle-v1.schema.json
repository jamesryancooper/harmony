{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/distillation-bundle-v1.schema.json",
  "title": "Octon Distillation Bundle v1",
  "description": "Canonical retained distillation bundle for proposal-gated clustering of recurring evidence patterns.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "bundle_kind",
    "subject_ref",
    "source_index_refs",
    "clusters",
    "promotion_mode",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "distillation-bundle-v1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_kind": {
      "type": "string",
      "enum": [
        "failure-distillation",
        "evidence-distillation"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_index_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cluster_id",
          "signal_kind",
          "summary",
          "source_evidence_refs"
        ],
        "properties": {
          "cluster_id": {
            "type": "string",
            "minLength": 1
          },
          "signal_kind": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source_evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "classifications": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "disagreement_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "evaluator_review_ref",
          "review_finding_refs",
          "review_disposition_refs",
          "summary",
          "source_evidence_refs",
          "calibration_candidate_refs"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "evaluator_review_ref": {
            "type": "string",
            "minLength": 1
          },
          "review_finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_disposition_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source_evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "calibration_candidate_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "calibration_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "target_refs",
          "summary",
          "proposed_change",
          "intended_effect",
          "evidence_refs",
          "status"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "target_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "proposed_change": {
            "type": "string",
            "minLength": 1
          },
          "intended_effect": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "trialed",
              "accepted",
              "rejected",
              "deferred"
            ]
          }
        }
      }
    },
    "promotion_mode": {
      "type": "string",
      "enum": [
        "proposal_gated"
      ]
    },
    "generated_summary_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
