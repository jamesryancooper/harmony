{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/proof-plane-report-v1.schema.json",
  "title": "Octon Proof Plane Report v1",
  "description": "Normalized retained proof output for a consequential run or system claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plane",
    "subject_kind",
    "subject_ref",
    "outcome",
    "proof_class",
    "summary",
    "evidence_refs",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "proof-plane-report-v1"
    },
    "plane": {
      "type": "string",
      "enum": [
        "structural",
        "functional",
        "behavioral",
        "maintainability",
        "governance",
        "recovery"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "run",
        "harness",
        "subsystem"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "stage_only",
        "not_required"
      ]
    },
    "proof_class": {
      "type": "string",
      "enum": [
        "deterministic",
        "lab",
        "replay",
        "scenario",
        "shadow-run",
        "mixed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
