{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/assurance/evaluator-review-v1.schema.json",
  "title": "Octon Evaluator Review v1",
  "description": "Independent evaluator review contract used when deterministic proof alone is insufficient.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_ref",
    "evaluator_id",
    "disposition",
    "summary",
    "evidence_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "evaluator-review-v1"
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "evaluator_id": {
      "type": "string",
      "minLength": 1
    },
    "disposition": {
      "type": "string",
      "enum": [
        "approved",
        "concerns",
        "blocked",
        "not_required"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
