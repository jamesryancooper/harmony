{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/constitution/contracts/authority/approval-grant-v1.schema.json",
  "title": "Octon Approval Grant v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "request_id",
    "run_id",
    "state",
    "issued_by",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": "authority-approval-grant-v1"
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "issued_by": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": ["string", "null"]
    },
    "quorum_policy_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "projection_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection_source"
      }
    },
    "review_metadata": {
      "type": "object"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authority_zone": {
      "$ref": "#/$defs/authority_zone"
    },
    "operation_class": {
      "$ref": "#/$defs/operation_class"
    },
    "artifact_class": {
      "$ref": "#/$defs/artifact_class"
    },
    "write_scope_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_authority_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "grant_scope_digest": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "authority_zone": {
      "type": "string",
      "enum": [
        "octon-run-bound",
        "octon-generated-derived",
        "octon-authored-governance",
        "workspace-declared",
        "current-run-agent-artifact",
        "protected-or-external"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "run-control",
        "run-evidence",
        "generated-derived",
        "authored-governance",
        "workspace-source",
        "current-run-generated",
        "protected-human-or-external",
        "unknown"
      ]
    },
    "operation_class": {
      "type": "string",
      "enum": [
        "inspect",
        "append-run-evidence",
        "update-run-control",
        "refresh-generated-projection",
        "cleanup-current-run-artifact",
        "retry-child-route",
        "execute-child-route",
        "program-recovery-action",
        "closeout-readiness",
        "durable-authority-mutation",
        "protected-artifact-mutation"
      ]
    },
    "projection_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
