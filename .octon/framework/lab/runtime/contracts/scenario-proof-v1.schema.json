{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/lab/runtime/contracts/scenario-proof-v1.schema.json",
  "title": "Octon Lab Scenario Proof v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "purpose",
    "subject_refs",
    "procedure",
    "evidence_refs",
    "outcome",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "lab-scenario-proof-v1"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "procedure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outcome": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "stage_only"
      ]
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
