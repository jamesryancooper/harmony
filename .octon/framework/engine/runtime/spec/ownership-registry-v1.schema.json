{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/ownership-registry-v1.schema.json",
  "title": "Ownership Registry v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "directive_precedence", "operators", "assets", "services", "subscriptions"],
  "properties": {
    "schema_version": { "const": "ownership-registry-v1" },
    "directive_precedence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "operators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["operator_id", "display_name", "contact"],
        "properties": {
          "operator_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "contact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assets": { "type": "array" },
    "services": { "type": "array" },
    "subscriptions": { "type": "object" }
  }
}
