{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/material-side-effect-inventory-v1.schema.json",
  "title": "Octon Material Side-Effect Inventory v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "classes", "paths"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "material-side-effect-inventory-v1"
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "token_type",
          "roots",
          "required_boundary",
          "owner",
          "risk_tier",
          "material"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "token_type": { "type": "string", "minLength": 1 },
          "roots": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "examples": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_boundary": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "risk_tier": { "type": "string", "minLength": 1 },
          "material": { "type": "boolean" }
        }
      }
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "path_id",
          "class_id",
          "owner_ref",
          "consumer_api_ref",
          "negative_bypass_test_ref",
          "consumption_receipt_required",
          "journal_event_required",
          "token_required",
          "coverage_state"
        ],
        "properties": {
          "path_id": { "type": "string", "minLength": 1 },
          "class_id": { "type": "string", "minLength": 1 },
          "owner_ref": { "type": "string", "minLength": 1 },
          "consumer_api_ref": { "type": "string", "minLength": 1 },
          "negative_bypass_test_ref": { "type": "string", "minLength": 1 },
          "consumption_receipt_required": { "type": "boolean" },
          "journal_event_required": { "type": "boolean" },
          "token_required": { "type": "boolean" },
          "coverage_state": {
            "type": "string",
            "enum": ["live", "stage_only", "retired", "denied"]
          }
        }
      }
    }
  }
}
