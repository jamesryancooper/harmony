{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/control-receipt-v1.schema.json",
  "title": "Control Receipt v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "mission_id",
    "receipt_type",
    "issued_by",
    "affected_paths"
  ],
  "properties": {
    "schema_version": { "const": "control-receipt-v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "receipt_type": { "type": "string", "minLength": 1 },
    "issued_by": { "type": "string", "minLength": 1 },
    "reason": { "type": "string" },
    "affected_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "linked_run_id": { "type": ["string", "null"] },
    "linked_directive_refs": { "type": "array", "items": { "type": "string" } },
    "linked_authorize_update_refs": { "type": "array", "items": { "type": "string" } }
  }
}
