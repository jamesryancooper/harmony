{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/control-receipt-v1.schema.json",
  "title": "Control Receipt v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "mission_id",
    "control_mutation_class",
    "source_ref",
    "applied_to_ref",
    "issuer_ref",
    "timestamp",
    "result",
    "reason_codes",
    "affected_paths"
  ],
  "properties": {
    "schema_version": { "const": "control-receipt-v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "control_mutation_class": {
      "type": "string",
      "enum": [
        "mission_seed",
        "directive_add",
        "directive_apply",
        "directive_reject",
        "directive_expire",
        "authorize_update_add",
        "authorize_update_apply",
        "authorize_update_reject",
        "authorize_update_expire",
        "schedule_mutation",
        "budget_transition",
        "breaker_trip",
        "breaker_reset",
        "safing_enter",
        "safing_exit",
        "break_glass_enter",
        "break_glass_exit",
        "finalize_block",
        "finalize_unblock",
        "mission_close"
      ]
    },
    "source_ref": { "type": "string", "minLength": 1 },
    "applied_to_ref": { "type": "string", "minLength": 1 },
    "issuer_ref": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "result": { "type": "string", "enum": ["applied", "rejected", "expired", "seeded", "closed"] },
    "prior_state_ref": { "type": ["string", "null"] },
    "new_state_ref": { "type": ["string", "null"] },
    "superseded_receipt_ref": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "affected_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "linked_run_id": { "type": ["string", "null"] },
    "linked_directive_refs": { "type": "array", "items": { "type": "string" } },
    "linked_authorize_update_refs": { "type": "array", "items": { "type": "string" } },
    "supersedes_receipt_id": { "type": ["string", "null"] }
  }
}
