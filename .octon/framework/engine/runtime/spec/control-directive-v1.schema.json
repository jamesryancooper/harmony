{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/control-directive-v1.schema.json",
  "title": "Control Directive v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "mission_id", "revision", "directives"],
  "properties": {
    "schema_version": { "const": "control-directive-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "directives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "directive_id",
          "type",
          "state",
          "issuer_ref",
          "issued_at",
          "payload",
          "consumed_by_receipt_ref"
        ],
        "properties": {
          "directive_id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": [
              "pause_at_boundary",
              "suspend_future_runs",
              "stop_after_slice",
              "reprioritize",
              "narrow_scope",
              "exclude_target",
              "block_finalize",
              "enter_safing"
            ]
          },
          "kind": { "type": "string", "minLength": 1 },
          "state": { "type": "string", "enum": ["pending", "applied", "rejected", "expired"] },
          "status": { "type": "string", "minLength": 1 },
          "issuer_ref": { "type": "string", "minLength": 1 },
          "submitted_by": { "type": "string", "minLength": 1 },
          "issued_at": { "type": "string", "minLength": 1 },
          "submitted_at": { "type": "string", "minLength": 1 },
          "expires_at": { "type": ["string", "null"] },
          "payload": { "type": "object" },
          "target_scope": { "type": "object" },
          "precedence_source": { "type": "string", "minLength": 1 },
          "effective_at": { "type": ["string", "null"] },
          "rationale": { "type": ["string", "null"] },
          "consumed_by_receipt_ref": { "type": ["string", "null"] }
        }
      }
    }
  }
}
