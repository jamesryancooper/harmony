{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/control-directive-v1.schema.json",
  "title": "Control Directive v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["directive_id", "directive_type", "issued_by", "issued_at", "status"],
  "properties": {
    "directive_id": { "type": "string", "minLength": 1 },
    "directive_type": { "type": "string", "minLength": 1 },
    "issued_by": { "type": "string", "minLength": 1 },
    "issued_at": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "scope": { "type": "object" },
    "reason": { "type": "string" }
  }
}
