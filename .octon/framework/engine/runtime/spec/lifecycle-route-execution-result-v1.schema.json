{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.dev/schemas/lifecycle-route-execution-result-v1.schema.json",
  "title": "Lifecycle Route Execution Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "route_id",
    "executor_used",
    "status",
    "started_at",
    "ended_at",
    "retryable",
    "next_action"
  ],
  "properties": {
    "schema_version": { "const": "octon-lifecycle-route-execution-result-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "route_id": { "type": "string", "minLength": 1 },
    "executor_used": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["completed", "no-op", "failed", "timed-out", "cancelled", "blocked", "authorization-proof-failed", "human-boundary-blocked", "executor-preflight-blocked"]
    },
    "receipts_observed": { "type": "array" },
    "evidence_paths": { "type": "array" },
    "retryable": { "type": "boolean" },
    "next_action": { "enum": ["replan", "manual-intervention", "cancelled", "rerun-with-approved-executor-access"] },
    "error_class": {
      "type": ["string", "null"],
      "enum": [
        null,
        "discovery",
        "input-binding",
        "authorization-proof-failed",
        "human-boundary-required",
        "executor-unavailable",
        "executor-failed",
        "timeout",
        "cancelled",
        "completion-not-observed",
        "partial-mutation",
        "receipt-invalid",
        "io"
      ]
    }
  }
}
