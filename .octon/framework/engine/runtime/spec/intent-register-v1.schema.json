{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/intent-register-v1.schema.json",
  "title": "Intent Register v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "mission_id", "revision", "generated_from", "entries"],
  "properties": {
    "schema_version": { "const": "intent-register-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "intent_id",
          "sequence",
          "action_slice_ref",
          "intent_ref",
          "action_class",
          "predicted_acp",
          "reversibility_class",
          "earliest_start",
          "default_on_silence",
          "operator_options",
          "expected_externality_class",
          "state"
        ],
        "properties": {
          "intent_id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "action_slice_ref": { "type": "string", "minLength": 1 },
          "intent_ref": { "type": "object" },
          "action_class": { "type": "string", "minLength": 1 },
          "predicted_acp": { "type": "string", "pattern": "^ACP-[0-4]$" },
          "reversibility_class": {
            "type": "string",
            "enum": ["reversible", "compensable", "irreversible"]
          },
          "earliest_start": { "type": "string", "minLength": 1 },
          "feedback_deadline": { "type": ["string", "null"] },
          "default_on_silence": { "type": "string", "minLength": 1 },
          "operator_options": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_externality_class": { "type": "string", "minLength": 1 },
          "state": {
            "type": "string",
            "enum": ["queued", "active", "consumed", "cancelled", "expired"]
          }
        }
      }
    }
  }
}
