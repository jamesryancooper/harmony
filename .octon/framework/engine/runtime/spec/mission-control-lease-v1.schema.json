{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/engine/runtime/spec/mission-control-lease-v1.schema.json",
  "title": "Mission Control Lease v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mission_id",
    "lease_id",
    "status",
    "granted_by",
    "granted_at",
    "expires_at",
    "max_concurrent_runs",
    "allowed_action_classes",
    "default_safing_subset"
  ],
  "properties": {
    "schema_version": { "const": "mission-control-lease-v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "lease_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "paused", "revoked", "expired"] },
    "granted_by": { "type": "string", "minLength": 1 },
    "granted_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "minLength": 1 },
    "max_concurrent_runs": { "type": "integer", "minimum": 0 },
    "allowed_action_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "default_safing_subset": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
