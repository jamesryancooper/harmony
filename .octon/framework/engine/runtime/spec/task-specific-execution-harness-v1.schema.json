{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octon.local/framework/engine/runtime/spec/task-specific-execution-harness-v1.schema.json",
  "title": "Octon Task-Specific Execution Harness v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "harness_id",
    "run_id",
    "task_ref",
    "statechart_ref",
    "bindings",
    "control_refs",
    "retained_evidence_refs",
    "generated_projection_policy",
    "authority_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "task-specific-execution-harness-v1"
    },
    "harness_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "run_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "task_ref": {
      "$ref": "#/$defs/nonAuthorityRuntimeRef"
    },
    "statechart_ref": {
      "const": ".octon/framework/engine/runtime/spec/workflow-statechart-v1.schema.json"
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective_binding",
        "run_contract_binding",
        "support_target_binding",
        "capability_envelope_binding",
        "context_pack_binding",
        "authorization_route_binding",
        "effect_token_class_binding",
        "evidence_obligation_binding",
        "rollback_or_compensation_binding",
        "human_intervention_binding",
        "model_cost_policy_binding",
        "closeout_criteria_binding"
      ],
      "properties": {
        "objective_binding": { "$ref": "#/$defs/binding" },
        "run_contract_binding": { "$ref": "#/$defs/binding" },
        "support_target_binding": { "$ref": "#/$defs/binding" },
        "capability_envelope_binding": { "$ref": "#/$defs/binding" },
        "context_pack_binding": { "$ref": "#/$defs/binding" },
        "authorization_route_binding": { "$ref": "#/$defs/binding" },
        "effect_token_class_binding": { "$ref": "#/$defs/binding" },
        "evidence_obligation_binding": { "$ref": "#/$defs/binding" },
        "rollback_or_compensation_binding": { "$ref": "#/$defs/binding" },
        "human_intervention_binding": { "$ref": "#/$defs/binding" },
        "model_cost_policy_binding": { "$ref": "#/$defs/binding" },
        "closeout_criteria_binding": { "$ref": "#/$defs/binding" }
      }
    },
    "control_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^\\.octon/state/control/"
      }
    },
    "retained_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^\\.octon/state/evidence/"
      }
    },
    "generated_projection_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\.octon/generated/cognition/projections/materialized/"
      }
    },
    "generated_projection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_status",
        "may_satisfy_runtime_authority",
        "may_satisfy_policy_authority",
        "may_satisfy_closeout_evidence"
      ],
      "properties": {
        "authority_status": { "const": "non_authoritative" },
        "may_satisfy_runtime_authority": { "const": false },
        "may_satisfy_policy_authority": { "const": false },
        "may_satisfy_closeout_evidence": { "const": false }
      }
    },
    "proposal_lineage_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\.octon/inputs/"
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness_authorizes_execution",
        "harness_mints_grants",
        "harness_consumes_effect_tokens",
        "harness_closes_runs",
        "harness_widens_support_claims"
      ],
      "properties": {
        "harness_authorizes_execution": { "const": false },
        "harness_mints_grants": { "const": false },
        "harness_consumes_effect_tokens": { "const": false },
        "harness_closes_runs": { "const": false },
        "harness_widens_support_claims": { "const": false }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonAuthorityRuntimeRef": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|/)\\.octon/(generated|inputs)/"
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "source_class",
        "binding_role"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/nonAuthorityRuntimeRef"
        },
        "source_class": {
          "type": "string",
          "enum": [
            "framework_authority",
            "instance_authority",
            "state_control",
            "state_evidence"
          ]
        },
        "binding_role": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
