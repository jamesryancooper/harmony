{
  "$schema": "../manifest.schema.json",
  "name": "proposal-policy-core",
  "description": "Subtype core files for policy proposals.",
  "inherits": "proposal-core",
  "additions": {
    "directories": [
      "policy",
      "implementation"
    ],
    "files": [
      "policy-proposal.yml",
      "policy/decision.md",
      "policy/policy-delta.md",
      "policy/enforcement-plan.md",
      "implementation/implementation-map.md"
    ]
  },
  "usage": "/create-policy-proposal"
}
