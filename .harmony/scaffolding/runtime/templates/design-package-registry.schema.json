{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Package Registry",
  "description": "Schema for the manifest-governed design-package registry.",
  "type": "object",
  "required": ["schema_version", "active", "archived"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "design-package-registry-v1"
    },
    "active": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "title",
          "package_class",
          "status",
          "implementation_targets"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "^\\.design-packages\\/[a-z][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "package_class": {
            "type": "string",
            "enum": ["domain-runtime", "experience-product"]
          },
          "status": {
            "type": "string",
            "enum": ["draft", "in-review", "implementation-ready"]
          },
          "implementation_targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "archived": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "title",
          "package_class",
          "status",
          "disposition",
          "archived_at",
          "archived_from_status",
          "original_path",
          "implementation_targets"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "^\\.design-packages\\/\\.archive\\/[a-z][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "package_class": {
            "type": "string",
            "enum": ["domain-runtime", "experience-product"]
          },
          "status": {
            "type": "string",
            "const": "archived"
          },
          "disposition": {
            "type": "string",
            "enum": ["implemented", "historical"]
          },
          "archived_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "archived_from_status": {
            "type": "string",
            "enum": ["draft", "in-review", "implementation-ready", "legacy-unknown"]
          },
          "original_path": {
            "type": "string",
            "minLength": 1
          },
          "implementation_targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
