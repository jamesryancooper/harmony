{
  "name": "harmony-theme",
  "displayName": "Harmony Theme",
  "description": "A beautiful color theme for Cursor/VS Code with light and dark variants.",
  "version": "1.0.0",
  "publisher": "harmony",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Harmony Light",
        "uiTheme": "vs",
        "path": "./themes/harmony-light.json"
      },
      {
        "label": "Harmony Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/harmony-dark.json"
      },
      {
        "label": "Harmony Markdown Light",
        "uiTheme": "vs",
        "path": "./themes/harmony-markdown-light.json"
      }
    ]
  }
}
