{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.local/schemas/spec-frontmatter.schema.json",
  "title": "Spec Front Matter",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the front matter schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
    },
    "feature": { "type": "string", "minLength": 2 },
    "author": { "type": "string", "minLength": 3 },
    "flag": { "type": "string" },
    "title": { "type": "string", "minLength": 3 },
    "contracts": {
      "type": "object",
      "properties": {
        "openapi": { "type": "string", "minLength": 1 },
        "schemas": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "required": ["openapi"],
      "additionalProperties": true
    },
    "slo_targets": {
      "type": "object",
      "properties": {
        "api_availability": { "type": "number", "minimum": 0, "maximum": 100 },
        "api_p95_ms": { "type": "integer", "minimum": 0 },
        "ttfb_p95_ms": { "type": "integer", "minimum": 0 },
        "error_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": true
    },
    "rollout": {
      "type": "object",
      "properties": {
        "audience": { "type": "string" },
        "rollback": { "type": "string" }
      },
      "additionalProperties": true
    },
    "threat_model": {
      "type": "object",
      "properties": {
        "stride": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "threat": { "type": "string" },
              "mitigations": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "required": ["threat", "mitigations"],
            "additionalProperties": true
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "standards": {
      "type": "object",
      "properties": {
        "asvs_v5_controls": { "type": "array", "items": { "type": "string" } },
        "nist_ssdf_activities": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "required": ["title", "contracts", "slo_targets", "threat_model", "standards", "acceptance_criteria"],
  "additionalProperties": true
}
