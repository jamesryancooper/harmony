{
  "schemaVersion": "1.3.0",
  "methodologyVersion": "0.2.0",
  "name": "promptkit",
  "version": "0.1.0",
  "description": "Runtime prompt compiler: template rendering, hashing, variant selection, token management, role assembly",
  "pillars": ["quality_through_determinism", "simplicity_over_complexity"],
  "lifecycleStages": ["implement"],
  "inputsSchema": "schema/promptkit.inputs.v1.json",
  "outputsSchema": "schema/promptkit.outputs.v1.json",
  "dependencies": {
    "requires": ["kit-base"],
    "orchestrates": [],
    "integratesWith": ["flowkit", "guardkit"]
  },
  "observability": {
    "serviceName": "harmony.kit.promptkit",
    "requiredSpans": ["kit.promptkit.compile"],
    "logRedaction": true
  },
  "policy": {
    "rulesetRef": "harmony-policy-v1",
    "rules": ["prompt-exists", "variables-valid", "within-context-window"],
    "rulesetVersion": "1.0.0",
    "enforcement": "block",
    "failClosed": true
  },
  "determinism": {
    "ai": {
      "promptHashAlgorithm": "sha256"
    },
    "artifactNaming": "{promptId}-{hash}"
  },
  "safety": {
    "hitl": {
      "requiredFor": []
    }
  },
  "idempotency": {
    "required": false,
    "idempotencyKeyFrom": ["promptId", "variablesHash", "variantId"]
  },
  "dryRun": {
    "supported": true
  },
  "compatibility": {
    "minSchemaVersion": "1.1.0",
    "maxSchemaVersion": "1.3.0",
    "supportedMethodologyVersions": ["0.2.0"],
    "contracts": ["promptkit.inputs.v1", "promptkit.outputs.v1"],
    "deprecations": [
      {
        "field": "compatibility.kits",
        "since": "1.3.0",
        "removeAt": "2.0.0",
        "migrationNote": "Use 'dependencies' object instead. See ARCHITECTURE.md for dependency type semantics."
      }
    ]
  }
}
