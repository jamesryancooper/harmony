{
  "name": "@harmony/kits",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "sh -c 'mkdir -p reports && eslint . -f json -o reports/eslint-kits.json'",
    "test": "tsx --test \"src/flowkit/__tests__/**/*.test.ts\"",
    "flowkit:run-config": "tsx src/flowkit/cli.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}

